# Prometheus configuration
# Generated by Ansible

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # Self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  # API server node exporter
  - job_name: 'node-api'
    static_configs:
      - targets: ['localhost:9100']
        labels:
          role: api

  # VPN node metrics
  - job_name: 'vpn-nodes'
    static_configs:
{% for host in groups['vpn_nodes'] %}
      - targets: ['{{ hostvars[host].ansible_host }}:{{ vpn_metrics_port }}']
        labels:
          region: {{ hostvars[host].region }}
          name: "{{ hostvars[host].server_name }}"
{% endfor %}

  # VPN node exporters
  - job_name: 'node-vpn'
    static_configs:
{% for host in groups['vpn_nodes'] %}
      - targets: ['{{ hostvars[host].ansible_host }}:9100']
        labels:
          region: {{ hostvars[host].region }}
{% endfor %}
