# VPN Server Configuration
# Generated by Ansible — do not edit manually

server_id = "{{ server_uuid }}"
capacity = {{ vpn_max_connections | default(1024) }}

listen_addr = "0.0.0.0:{{ vpn_listen_port }}"

tls_cert_path = "/etc/letsencrypt/live/{{ inventory_hostname }}.{{ base_domain }}/fullchain.pem"
tls_key_path = "/etc/letsencrypt/live/{{ inventory_hostname }}.{{ base_domain }}/privkey.pem"

tunnel_subnet = "{{ vpn_tunnel_subnet }}"
tunnel_ip_start = "{{ vpn_tunnel_ip_start }}"
tunnel_ip_end = "{{ vpn_tunnel_ip_end }}"
tunnel_gateway = "{{ vpn_tunnel_gateway }}"

dns_servers = [{{ vpn_dns_servers | map('regex_replace', '^(.*)$', '"\1"') | join(', ') }}]

mtu = {{ vpn_mtu }}
jwt_secret = "{{ vpn_session_secret }}"
idle_timeout_secs = {{ vpn_idle_timeout }}
metrics_addr = "127.0.0.1:{{ vpn_metrics_port }}"
upgrade_path = "/ws"
